				{
					"name": "1. User Login (تسجيل الدخول)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set(\"authToken\", jsonData.data.token);",
									"    pm.collectionVariables.set(\"tenantId\", jsonData.data.tenantId);",
									"    console.log(\"Saved JWT token and Tenant ID successfully!\");",
									"}"
								],
								"type": "javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"owner@rasd.com\",\n  \"password\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/Auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"Auth",
								"login"
							]
						},
						"description": "يقوم بتسجيل دخول المستخدم وإرجاع الـ JWT Token وبيانات المستخدم والشركة. يقوم Postman بحفظ الـ Token تلقائياً في المتغيرات بعد نجاح الطلب."
					},
					"response": []
				},
